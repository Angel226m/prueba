@* ============================================================
   Views/Home/Error.cshtml — Página de error genérica CEPLAN
   No revela detalles internos (OWASP A05).
   ============================================================ *@
@{ ViewData["Title"] = "Error"; Layout = null; }
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error — CEPLAN</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Outfit', sans-serif; background: #F4F5F7; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }
        .card { background: #fff; border-radius: 16px; padding: 48px 40px; max-width: 420px; width: 100%; text-align: center; box-shadow: 0 8px 32px rgba(0,0,0,.1); }
        .ico { font-size: 3.5rem; margin-bottom: 20px; }
        h1 { font-size: 1.4rem; font-weight: 700; color: #1E2533; margin-bottom: 12px; }
        p { font-size: .9rem; color: #6B7280; line-height: 1.65; margin-bottom: 28px; }
        a { display: inline-block; padding: 12px 28px; background: #7B1618; color: #fff; border-radius: 9px; text-decoration: none; font-weight: 600; font-size: .93rem; transition: background .2s; }
        a:hover { background: #5e1012; }
    </style>
</head>
<body>
    <div class="card">
        <div class="ico">⚠️</div>
        <h1>Ha ocurrido un error</h1>
        <p>Por favor intenta nuevamente o contacta al administrador del sistema.</p>
        <a href="/Account/Login">Volver al inicio</a>
    </div>
</body>
</html>
