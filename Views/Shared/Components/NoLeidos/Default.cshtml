@* ============================================================
   Views/Shared/Components/NoLeidos/Default.cshtml
   Renderiza el badge numérico de mensajes no leídos.
   Usado en _Layout.cshtml vía @await Component.InvokeAsync("NoLeidos")
   ============================================================ *@
@model int
@if (Model > 0)
{
    <span class="badge-nl">@(Model > 99 ? "99+" : Model.ToString())</span>
}
