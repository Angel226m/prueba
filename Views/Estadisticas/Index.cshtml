@* Views/Estadisticas/Index.cshtml — Dashboard de métricas CEPLAN *@
@using LoginAppCore.Models
@{
    ViewData["Title"] = "Estadísticas del Sistema";
    var stats = (EstadisticasHoy?)ViewBag.Stats;
}

<style>
    .stats-wrap { padding:14px 20px 0; max-width:1200px; margin:0 auto; }
    .stats-bread { font-size:.7rem; color:#9CA3AF; margin-bottom:3px; }
    .stats-title { font-size:1.3rem; font-weight:700; color:#1E2533; margin-bottom:14px; }

    .stats-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:14px; margin-bottom:20px; }
    .stat-card { background:#fff; border:1px solid #E5E7EB; border-radius:8px; padding:16px; }
    .stat-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
    .stat-title { font-size:.8rem; font-weight:600; color:#6B7280; text-transform:uppercase; letter-spacing:.5px; }
    .stat-icon { width:24px; height:24px; padding:4px; border-radius:6px; background:#F3F4F6; }
    .stat-value { font-size:2rem; font-weight:700; color:#1E2533; line-height:1; margin-bottom:4px; }
    .stat-desc { font-size:.75rem; color:#9CA3AF; }

    .chart-section { background:#fff; border:1px solid #E5E7EB; border-radius:8px; padding:20px; margin-bottom:20px; }
    .chart-title { font-size:1rem; font-weight:600; color:#1E2533; margin-bottom:12px; }
    .chart-placeholder {
        height:200px; background:linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
        border-radius:8px; display:flex; align-items:center; justify-content:center;
        font-size:.85rem; color:#6B7280; text-align:center;
    }

    .activity-section { background:#fff; border:1px solid #E5E7EB; border-radius:8px; padding:20px; }
    .activity-item { display:flex; align-items:center; gap:12px; padding:8px 0; border-bottom:1px solid #F3F4F6; }
    .activity-item:last-child { border-bottom:none; }
    .activity-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .activity-dot.success { background:#10B981; }
    .activity-dot.warning { background:#F59E0B; }
    .activity-dot.error { background:#EF4444; }
    .activity-content { flex:1; }
    .activity-text { font-size:.8rem; color:#374151; margin-bottom:1px; }
    .activity-time { font-size:.7rem; color:#9CA3AF; }

    @@media (max-width:768px) {
        .stats-wrap { padding:8px 12px 0; }
        .stats-grid { grid-template-columns:1fr; }
    }
</style>

<div class="stats-wrap">
    <p class="stats-bread">Dashboard &gt; Estadísticas</p>
    <h1 class="stats-title">Estadísticas del Sistema</h1>

    @if (stats != null)
    {
        <!-- Métricas principales -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-title">Accesos Exitosos</span>
                    <div class="stat-icon" style="background:#ECFDF5;">
                        <svg viewBox="0 0 16 16" fill="#10B981">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.061L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
                        </svg>
                    </div>
                </div>
                <div class="stat-value">@stats.AccesosOk</div>
                <div class="stat-desc">Logins correctos hoy</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-title">Intentos Fallidos</span>
                    <div class="stat-icon" style="background:#FEF3F2;">
                        <svg viewBox="0 0 16 16" fill="#EF4444">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293 5.354 4.646z"/>
                        </svg>
                    </div>
                </div>
                <div class="stat-value">@stats.IntentosFallidos</div>
                <div class="stat-desc">Intentos de login fallidos</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-title">Total Usuarios</span>
                    <div class="stat-icon" style="background:#EFF6FF;">
                        <svg viewBox="0 0 16 16" fill="#3B82F6">
                            <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002A.274.274 0 0 1 15 13H7.022zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816zM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275zM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0zm3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
                        </svg>
                    </div>
                </div>
                <div class="stat-value">@stats.TotalUsuarios</div>
                <div class="stat-desc">Usuarios registrados</div>
            </div>

            <div class="stat-card">
                <div class="stat-header">
                    <span class="stat-title">Tasa de Éxito</span>
                    <div class="stat-icon" style="background:#F0FDF4;">
                        <svg viewBox="0 0 16 16" fill="#059669">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zM8.287 5.906c-.778.324-2.334.994-4.637 2.01A.83.83 0 0 0 3 8.79c0 .446.36.81.806.81h2.388c.448 0 .81-.364.81-.81 0-.446-.362-.81-.81-.81H5.084l1.33-.532c1.797-.718 3.49-1.391 4.734-1.886A.83.83 0 0 0 11.5 5c0-.444-.358-.806-.804-.806a.83.83 0 0 0-.409.712z"/>
                        </svg>
                    </div>
                </div>
                <div class="stat-value">
                    @{
                        var total = stats.AccesosOk + stats.IntentosFallidos;
                        var tasa = total > 0 ? (stats.AccesosOk * 100.0 / total).ToString("F1") : "0.0";
                    }
                    @tasa%
                </div>
                <div class="stat-desc">Ratio de éxito en login</div>
            </div>
        </div>
    }
    else
    {
        <div class="stat-card">
            <p style="color:#6B7280; font-size:.9rem; text-align:center; margin:20px 0;">
                No se pudieron cargar las estadísticas del sistema.
            </p>
        </div>
    }

    <!-- Gráfico de actividad -->
    <div class="chart-section">
        <h3 class="chart-title">Actividad de Login (Últimas 24h)</h3>
        <div class="chart-placeholder">
            <div>
                <i class="bi bi-bar-chart-line" style="font-size:2rem; margin-bottom:8px; display:block;"></i>
                Gráfico de actividad en tiempo real<br />
                <small>En desarrollo - Próxima actualización</small>
            </div>
        </div>
    </div>

    <!-- Actividad reciente -->
    <div class="activity-section">
        <h3 class="chart-title">Actividad Reciente del Sistema</h3>
        <div class="activity-item">
            <div class="activity-dot success"></div>
            <div class="activity-content">
                <div class="activity-text">Usuario @(User.Identity?.Name ?? "Angel") inició sesión exitosamente</div>
                <div class="activity-time">Hace 2 minutos</div>
            </div>
        </div>
        <div class="activity-item">
            <div class="activity-dot success"></div>
            <div class="activity-content">
                <div class="activity-text">Sistema de backup completado correctamente</div>
                <div class="activity-time">Hace 1 hora</div>
            </div>
        </div>
        <div class="activity-item">
            <div class="activity-dot warning"></div>
            <div class="activity-content">
                <div class="activity-text">Rate limiting activado para IP 192.168.1.100</div>
                <div class="activity-time">Hace 2 horas</div>
            </div>
        </div>
        <div class="activity-item">
            <div class="activity-dot error"></div>
            <div class="activity-content">
                <div class="activity-text">Intento fallido de login desde IP desconocida</div>
                <div class="activity-time">Hace 3 horas</div>
            </div>
        </div>
        <div class="activity-item">
            <div class="activity-dot success"></div>
            <div class="activity-content">
                <div class="activity-text">Actualización de seguridad aplicada correctamente</div>
                <div class="activity-time">Hace 6 horas</div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()